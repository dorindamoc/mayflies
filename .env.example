# Mayflies — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Matrix homeserver (e.g. https://matrix.org or your own server)
MATRIX_HOMESERVER=https://matrix.org

# Bot account credentials
MATRIX_ACCESS_TOKEN=your_bot_access_token_here
MATRIX_BOT_USER=@mayflies:matrix.org

# Founder (human who receives and sends messages)
MATRIX_HUMAN_USER=@you:matrix.org
MATRIX_HUMAN_NAME=Dorin

# Shared room where the conversation happens
MATRIX_ROOM_ID=!roomid:matrix.org

# Optional: AI friend room (leave blank to disable)
MATRIX_FRIEND_ROOM_ID=

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-api03-...

# Voting: net votes needed to canonize a proposal (default: 3)
VOTE_THRESHOLD=3

# Daily message limit to the AI friend room (default: 10)
FRIEND_MESSAGE_LIMIT=10
